# Backstage PyActions — Environment Configuration
# Copy this file to .env and fill in your values.

# App
APP_NAME=Backstage PyActions
APP_PORT=8000
DEBUG=false

# Security — set this to require an API token from Backstage
# Leave empty to disable authentication
API_TOKEN=

# Git Provider (optional — only needed if using the providers layer)
# Supported: "gitlab" or "github"
GIT_PROVIDER=gitlab
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
